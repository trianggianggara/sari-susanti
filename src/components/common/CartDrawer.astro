---
import type { Locale } from '../../i18n/utils';
import { WHATSAPP_NUMBER } from '../../lib/constants';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isEn = locale === 'en';
---

<!-- Cart Drawer Overlay -->
<div class="cart-overlay" id="cart-overlay" aria-hidden="true"></div>

<!-- Cart Drawer Panel -->
<aside class="cart-drawer" id="cart-drawer" aria-label={isEn ? 'Shopping Cart' : 'Keranjang Belanja'} role="dialog" aria-modal="true">
  <div class="cart-drawer__header">
    <div class="cart-drawer__title-group">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="9" cy="21" r="1"></circle>
        <circle cx="20" cy="21" r="1"></circle>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
      </svg>
      <h2 class="cart-drawer__title">{isEn ? 'My Order' : 'Pesanan Saya'}</h2>
      <span class="cart-badge" id="cart-badge-drawer">0</span>
    </div>
    <button class="cart-drawer__close" id="cart-close" aria-label={isEn ? 'Close cart' : 'Tutup keranjang'}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Empty state -->
  <div class="cart-empty" id="cart-empty">
    <div class="cart-empty__icon" aria-hidden="true">🍽️</div>
    <p class="cart-empty__text">
      {isEn ? 'Your order is empty' : 'Pesanan Anda kosong'}
    </p>
    <p class="cart-empty__sub">
      {isEn ? 'Add items from our menu to get started' : 'Tambahkan item dari menu kami untuk memulai'}
    </p>
    <a href={isEn ? '/en/menu' : '/menu'} class="btn btn--outline cart-empty__cta" id="cart-menu-link">
      {isEn ? 'Browse Menu' : 'Lihat Menu'}
    </a>
  </div>

  <!-- Items list -->
  <div class="cart-items" id="cart-items"></div>

  <!-- Footer: total + WhatsApp CTA -->
  <div class="cart-footer" id="cart-footer">
    <div class="cart-footer__summary">
      <span class="cart-footer__label">{isEn ? 'Total Items' : 'Total Item'}</span>
      <span class="cart-footer__count" id="cart-total-count">0 {isEn ? 'items' : 'item'}</span>
    </div>
    <div class="cart-footer__note">
      {isEn ? 'Prices will be confirmed via WhatsApp' : 'Harga akan dikonfirmasi via WhatsApp'}
    </div>
    <a
      href="#"
      class="btn btn--primary cart-footer__cta"
      id="cart-whatsapp-btn"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="margin-right: 8px; flex-shrink: 0;">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      {isEn ? 'Order via WhatsApp' : 'Pesan via WhatsApp'}
    </a>
    <button class="cart-footer__clear" id="cart-clear-btn">
      {isEn ? 'Clear order' : 'Kosongkan pesanan'}
    </button>
  </div>
</aside>



<!-- Cart Toggle Button (floating, shown on all pages) -->
<button class="cart-fab" id="cart-fab" aria-label={isEn ? 'View cart' : 'Lihat keranjang'} style="display:none;">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="9" cy="21" r="1"></circle>
    <circle cx="20" cy="21" r="1"></circle>
    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
  </svg>
  <span class="cart-fab__count" id="cart-fab-count">0</span>
</button>

<script define:vars={{ waNumber: WHATSAPP_NUMBER, locale }}>
  import('/src/lib/cart-store.ts').catch(() => {});

  document.addEventListener('astro:page-load', () => {
    // We inline the cart logic here since this is a static-ish component
    const CART_KEY = 'ss_cart';
    const CART_EVENT = 'ss:cart-updated';

    function getItems() {
      try { return JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch { return []; }
    }
    function saveItems(items) {
      localStorage.setItem(CART_KEY, JSON.stringify(items));
      window.dispatchEvent(new CustomEvent(CART_EVENT, { detail: items }));
    }

    // ── DOM refs ──────────────────────────────────────────────────
    const overlay   = document.getElementById('cart-overlay');
    const drawer    = document.getElementById('cart-drawer');
    const closeBtn  = document.getElementById('cart-close');
    const fab       = document.getElementById('cart-fab');
    const fabCount  = document.getElementById('cart-fab-count');
    const drawerBadge = document.getElementById('cart-badge-drawer');
    const emptyEl   = document.getElementById('cart-empty');
    const itemsEl   = document.getElementById('cart-items');
    const footerEl  = document.getElementById('cart-footer');
    const totalCount = document.getElementById('cart-total-count');
    const waBtn     = document.getElementById('cart-whatsapp-btn');
    const clearBtn  = document.getElementById('cart-clear-btn');

    const isEn = locale === 'en';

    // ── Open / Close ──────────────────────────────────────────────
    function openCart() {
      drawer?.classList.add('is-open');
      overlay?.classList.add('is-visible');
      document.body.style.overflow = 'hidden';
      drawer?.focus();
    }
    function closeCart() {
      drawer?.classList.remove('is-open');
      overlay?.classList.remove('is-visible');
      document.body.style.overflow = '';
    }

    fab?.addEventListener('click', openCart);
    closeBtn?.addEventListener('click', closeCart);
    overlay?.addEventListener('click', closeCart);
    
    // Use an object to track if we've bound global events
    window.__ssCartInit = window.__ssCartInit || {};

    if (!window.__ssCartInit.keydown) {
      document.addEventListener('keydown', (e) => { 
        if (e.key === 'Escape') {
          const activeDrawer = document.getElementById('cart-drawer');
          if (activeDrawer?.classList.contains('is-open')) {
            activeDrawer.classList.remove('is-open');
            const activeOverlay = document.getElementById('cart-overlay');
            activeOverlay?.classList.remove('is-visible');
            document.body.style.overflow = '';
          }
        }
      });
      window.__ssCartInit.keydown = true;
    }

    // Listen for open-cart events from Add-to-Cart buttons
    if (!window.__ssCartInit.openCart) {
      window.addEventListener('ss:open-cart', () => {
        const d = document.getElementById('cart-drawer');
        const o = document.getElementById('cart-overlay');
        d?.classList.add('is-open');
        o?.classList.add('is-visible');
        document.body.style.overflow = 'hidden';
      });
      window.__ssCartInit.openCart = true;
    }

    // ── Render ────────────────────────────────────────────────────
    function renderCartItem(item) {
      const div = document.createElement('div');
      div.className = 'cart-item';
      div.dataset.slug = item.slug;
      div.innerHTML = `
        <img class="cart-item__img" src="${item.image || '/placeholder.jpg'}" alt="${item.name}" />
        <div class="cart-item__info">
          <span class="cart-item__name">${item.name}</span>
          ${item.price ? `<span class="cart-item__price">${isEn ? 'From' : 'Mulai'} Rp ${Number(item.price).toLocaleString('id-ID')}</span>` : ''}
        </div>
        <div class="cart-item__controls">
          <button class="cart-qty-btn" data-action="dec" data-slug="${item.slug}" aria-label="Kurangi">−</button>
          <span class="cart-qty-val">${item.qty}</span>
          <button class="cart-qty-btn" data-action="inc" data-slug="${item.slug}" aria-label="Tambah">+</button>
          <button class="cart-remove" data-slug="${item.slug}" aria-label="${isEn ? 'Remove' : 'Hapus'}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      `;
      return div;
    }

    function buildWaUrl(items) {
      if (!items.length) return `https://wa.me/${waNumber}`;
      let msg = isEn
        ? "Hello Sari Susanti! I'd like to order:\n\n"
        : 'Halo Sari Susanti! Saya ingin memesan:\n\n';
      items.forEach((item, i) => { msg += `${i+1}. *${item.name}* × ${item.qty}\n`; });
      msg += isEn
        ? '\nPlease let me know availability and pricing. Thank you 🙏'
        : '\nMohon informasi ketersediaan dan harganya. Terima kasih 🙏';
      return `https://wa.me/${waNumber}?text=${encodeURIComponent(msg)}`;
    }

    function renderCart(items) {
      const count = items.reduce((s, i) => s + i.qty, 0);
      
      const fabEl = document.getElementById('cart-fab');
      const fabCountEl = document.getElementById('cart-fab-count');
      const drawerBadgeEl = document.getElementById('cart-badge-drawer');
      const emptyStateEl = document.getElementById('cart-empty');
      const itemsContainer = document.getElementById('cart-items');
      const footerContainer = document.getElementById('cart-footer');
      const totalCountEl = document.getElementById('cart-total-count');
      const waBtnEl = document.getElementById('cart-whatsapp-btn');

      // Update badges
      if (fabCountEl) fabCountEl.textContent = String(count);
      if (drawerBadgeEl) drawerBadgeEl.textContent = String(count);
      if (totalCountEl) totalCountEl.textContent = `${count} ${isEn ? (count === 1 ? 'item' : 'items') : 'item'}`;

      // FAB visibility
      if (fabEl) fabEl.style.display = count > 0 ? 'flex' : 'none';

      // Empty vs filled
      const isEmpty = items.length === 0;
      if (emptyStateEl) emptyStateEl.style.display = isEmpty ? 'flex' : 'none';
      if (itemsContainer) itemsContainer.style.display = isEmpty ? 'none' : 'block';
      if (footerContainer) footerContainer.style.display = isEmpty ? 'none' : 'flex';

      // Render items
      if (itemsContainer) {
        itemsContainer.innerHTML = '';
        items.forEach(item => itemsContainer.appendChild(renderCartItem(item)));
      }

      // WA link
      if (waBtnEl) waBtnEl.href = buildWaUrl(items);
    }

    // ── Event delegation for qty/remove ──────────────────────────
    itemsEl?.addEventListener('click', (e) => {
      const target = e.target;
      const btn = target.closest('[data-action],[data-slug]');
      if (!btn) return;

      const slug = btn.dataset.slug;
      const action = btn.dataset.action;
      const items = getItems();
      const item = items.find(i => i.slug === slug);
      if (!item) return;

      if (action === 'inc') {
        item.qty += 1;
        saveItems(items);
      } else if (action === 'dec') {
        item.qty -= 1;
        if (item.qty <= 0) saveItems(items.filter(i => i.slug !== slug));
        else saveItems(items);
      } else if (btn.classList.contains('cart-remove')) {
        saveItems(items.filter(i => i.slug !== slug));
      }
    });

    clearBtn?.addEventListener('click', async () => {
      const { showConfirmDialog } = await import('/src/lib/dialog.ts');
      const msg = isEn
        ? 'All items in your cart will be removed. This cannot be undone.'
        : 'Semua item dalam keranjang akan dihapus. Tindakan ini tidak bisa dibatalkan.';
      const label = isEn ? 'Yes, Clear' : 'Ya, Kosongkan';
      const title = isEn ? 'Clear Order?' : 'Kosongkan Pesanan?';
      const confirmed = await showConfirmDialog(msg, { title, confirmLabel: label });
      if (confirmed) saveItems([]);
    });

    // ── Init & reactive updates ───────────────────────────────────
    renderCart(getItems());
    
    if (!window.__ssCartInit.cartEvent) {
      window.addEventListener(CART_EVENT, (e) => renderCart(e.detail));
      window.__ssCartInit.cartEvent = true;
    }
  });
</script>

<style>
/* ── Overlay ── */
.cart-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 900;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.cart-overlay.is-visible {
  opacity: 1;
  pointer-events: all;
}

/* ── Drawer ── */
.cart-drawer {
  position: fixed;
  top: 0;
  right: 0;
  width: 400px;
  max-width: 100vw;
  height: 100dvh;
  background: var(--color-white);
  z-index: 901;
  display: flex;
  flex-direction: column;
  box-shadow: -4px 0 40px rgba(0, 0, 0, 0.12);
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}
.cart-drawer.is-open {
  transform: translateX(0);
}

/* ── Drawer Header ── */
.cart-drawer__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-5) var(--space-6);
  border-bottom: 1px solid var(--color-sand);
  flex-shrink: 0;
}
.cart-drawer__title-group {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  color: var(--color-charcoal);
}
.cart-drawer__title {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--color-charcoal);
}
.cart-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 20px;
  height: 20px;
  padding: 0 5px;
  background: var(--color-emerald);
  color: var(--color-white);
  border-radius: var(--radius-full);
  font-size: 11px;
  font-weight: 700;
}
.cart-drawer__close {
  width: 36px;
  height: 36px;
  border: none;
  background: var(--color-ivory);
  border-radius: var(--radius-full);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-charcoal);
  transition: background 0.2s;
}
.cart-drawer__close:hover {
  background: var(--color-sand);
}

/* ── Empty State ── */
.cart-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-10) var(--space-6);
  text-align: center;
  gap: var(--space-3);
}
.cart-empty__icon {
  font-size: 3rem;
  line-height: 1;
}
.cart-empty__text {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 600;
  color: var(--color-charcoal);
}
.cart-empty__sub {
  font-size: var(--text-sm);
  color: var(--color-stone);
  max-width: 30ch;
}
.cart-empty__cta {
  margin-top: var(--space-2);
}

/* ── Items List ── */
.cart-items {
  flex: 1;
  overflow-y: auto;
  padding: var(--space-4) var(--space-6);
  display: none;
}

/* ── Cart Item ── */
.cart-item {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-4) 0;
  border-bottom: 1px solid var(--color-sand);
}
.cart-item:last-child {
  border-bottom: none;
}
.cart-item__img {
  width: 64px;
  height: 64px;
  border-radius: var(--radius-lg);
  object-fit: cover;
  flex-shrink: 0;
  border: 1px solid var(--color-sand);
}
.cart-item__info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.cart-item__name {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-charcoal);
  line-height: 1.3;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.cart-item__price {
  font-size: var(--text-xs);
  color: var(--color-emerald);
  font-weight: 500;
}
.cart-item__controls {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  flex-shrink: 0;
}
.cart-qty-btn {
  width: 28px;
  height: 28px;
  border: 1.5px solid var(--color-sand);
  background: var(--color-white);
  border-radius: var(--radius-md);
  cursor: pointer;
  font-size: var(--text-base);
  line-height: 1;
  color: var(--color-charcoal);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border-color 0.15s, background 0.15s;
}
.cart-qty-btn:hover {
  border-color: var(--color-emerald);
  background: var(--color-emerald-glass);
  color: var(--color-emerald);
}
.cart-qty-val {
  width: 24px;
  text-align: center;
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-charcoal);
}
.cart-remove {
  width: 28px;
  height: 28px;
  border: none;
  background: none;
  cursor: pointer;
  color: var(--color-stone);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  margin-left: var(--space-1);
  transition: color 0.15s, background 0.15s;
}
.cart-remove:hover {
  color: #c0392b;
  background: #fdf0ef;
}

/* ── Footer ── */
.cart-footer {
  padding: var(--space-5) var(--space-6);
  border-top: 1px solid var(--color-sand);
  display: none;
  flex-direction: column;
  gap: var(--space-3);
  background: var(--color-white);
  flex-shrink: 0;
}
.cart-footer__summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: var(--text-sm);
  color: var(--color-charcoal);
}
.cart-footer__label {
  color: var(--color-stone);
}
.cart-footer__count {
  font-weight: 700;
}
.cart-footer__note {
  font-size: var(--text-xs);
  color: var(--color-stone);
  text-align: center;
  padding: var(--space-2) var(--space-3);
  background: var(--color-ivory);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-sand);
}
.cart-footer__cta {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}
.cart-footer__clear {
  background: none;
  border: none;
  cursor: pointer;
  font-size: var(--text-xs);
  color: var(--color-stone);
  text-decoration: underline;
  text-align: center;
  padding: 0;
  transition: color 0.15s;
}
.cart-footer__clear:hover {
  color: #c0392b;
}


/* ── FAB (Floating Cart Button) ── */
.cart-fab {
  position: fixed;
  bottom: calc(var(--space-6) + 64px); /* above WhatsApp button */
  right: var(--space-6);
  width: 52px;
  height: 52px;
  border-radius: var(--radius-full);
  background: var(--color-emerald);
  color: var(--color-white);
  border: none;
  cursor: pointer;
  display: none;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 20px rgba(45, 90, 39, 0.4);
  z-index: 800;
  transition: transform 0.2s, box-shadow 0.2s;
}
.cart-fab:hover {
  transform: scale(1.08);
  box-shadow: 0 6px 24px rgba(45, 90, 39, 0.5);
}
.cart-fab__count {
  position: absolute;
  top: -4px;
  right: -4px;
  min-width: 20px;
  height: 20px;
  background: var(--color-gold);
  color: var(--color-charcoal);
  border-radius: var(--radius-full);
  font-size: 11px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
  border: 2px solid white;
}
</style>
