---
import { getAlternateLocale, getLocalePath, LOCALES } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentPath = Astro.url.pathname;
const alternateLocale = getAlternateLocale(locale);
const alternatePath = getLocalePath(currentPath, alternateLocale);
---

<a href={alternatePath} class="lang-switcher" aria-label={`Switch to ${alternateLocale.toUpperCase()}`}>
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10"></circle>
    <line x1="2" y1="12" x2="22" y2="12"></line>
    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
  </svg>
  <span>{alternateLocale.toUpperCase()}</span>
</a>
