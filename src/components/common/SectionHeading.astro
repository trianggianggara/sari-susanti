---
export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
}

const { eyebrow, title, subtitle, align = 'center' } = Astro.props;
---

<div class:list={['section-heading', `section-heading--${align}`, 'reveal']}>
  {eyebrow && <span class="section-eyebrow">{eyebrow}</span>}
  <h2 class="section-title" set:html={title}></h2>
  {subtitle && <p class="section-subtitle">{subtitle}</p>}
</div>
