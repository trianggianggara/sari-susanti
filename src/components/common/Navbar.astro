---
import type { Locale } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { BRAND } from '../../lib/constants';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const prefix = locale === 'id' ? '' : `/${locale}`;

const navItems = [
  { label: t('nav.home'), href: `${prefix}/` },
  { label: t('nav.menu'), href: `${prefix}/menu` },
  { label: t('nav.about'), href: `${prefix}/about-us` },
  { label: t('nav.faq'), href: `${prefix}/faq` },
  { label: t('nav.contact'), href: `${prefix}/contact` },
];

const currentPath = Astro.url.pathname;

// The middleware rewrites e.g. /about-us → /id/about-us internally.
// Astro.url.pathname returns the REWRITTEN path, so strip the /id prefix
// for ID locale to compare against item hrefs correctly.
const normalizedPath = (prefix === '' && currentPath.startsWith('/id'))
  ? currentPath.slice(3) || '/'   // strip "/id" → "/about-us"
  : currentPath;

const isHome = 
  normalizedPath === '/' || 
  normalizedPath === `${prefix}/` || 
  normalizedPath === prefix;
---

<!-- Backdrop overlay -->
<div class="nav__overlay" id="nav-overlay" aria-hidden="true"></div>

<header class:list={['nav', { 'nav--solid': !isHome }]} id="main-nav">
  <div class="container nav__inner">
    <a href={`${prefix}/`} class="nav__logo">
      <img src="/logo.png" alt="Sari Susanti Logo" style="height: 60px; width: auto; object-fit: contain;" class="nav-logo-img" />
    </a>

    <nav class="nav__links">
      {navItems.map((item) => (
        <a 
          href={item.href} 
          class:list={['nav__link', { 'is-active': normalizedPath === item.href || (item.href !== `${prefix}/` && normalizedPath.startsWith(item.href)) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="nav__actions">
      <span class="nav__lang-desktop">
        <LanguageSwitcher locale={locale} />
      </span>
      <a href={`${prefix}/order`} class="btn btn-primary btn-sm nav__order-btn">
        {t('nav.order')}
      </a>
      <button class="nav__hamburger" id="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="nav__mobile" id="mobile-menu" role="dialog" aria-modal="true" aria-label="Navigation Menu">
    <!-- Panel header: logo only -->
    <div class="nav__mobile-header">
      <a href={`${prefix}/`} class="nav__logo nav__mobile-logo">
        <img src="/logo.png" alt="Sari Susanti Logo" style="height: 44px; width: auto; object-fit: contain;" />
      </a>
      <button class="nav__mobile-close" id="mobile-menu-close" aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Nav links -->
    <nav class="nav__mobile-links">
      {navItems.map((item) => (
        <a 
          href={item.href} 
          class:list={['nav__link', { 'is-active': normalizedPath === item.href || (item.href !== `${prefix}/` && normalizedPath.startsWith(item.href)) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Panel footer: tagline + lang -->
    <div class="nav__mobile-footer">
      <span class="nav__mobile-footer-tagline">{BRAND.tagline}</span>
      <LanguageSwitcher locale={locale} />
    </div>
  </div>
</header>

<script>
  // Setup navbar scroll effect and mobile menu toggle
  document.addEventListener('astro:page-load', () => {
    const nav      = document.getElementById('main-nav');
    const toggle   = document.getElementById('nav-toggle');
    const overlay  = document.getElementById('nav-overlay');
    const menu     = document.getElementById('mobile-menu');

    function openMenu() {
      menu?.classList.add('is-open');
      overlay?.classList.add('is-visible');
      document.body.style.overflow = 'hidden';
      toggle?.setAttribute('aria-expanded', 'true');
      const spans = toggle?.querySelectorAll('span') as NodeListOf<HTMLElement>;
      if (spans) {
        (spans[0] as HTMLElement).style.transform = 'translateY(3.75px) rotate(45deg)';
        (spans[0] as HTMLElement).style.width = '100%';
        (spans[1] as HTMLElement).style.transform = 'translateY(-3.75px) rotate(-45deg)';
        (spans[1] as HTMLElement).style.width = '100%';
      }
    }

    function closeMenu() {
      menu?.classList.remove('is-open');
      overlay?.classList.remove('is-visible');
      document.body.style.overflow = '';
      toggle?.setAttribute('aria-expanded', 'false');
      const spans = toggle?.querySelectorAll('span') as NodeListOf<HTMLElement>;
      if (spans) {
        (spans[0] as HTMLElement).style.transform = 'none';
        (spans[0] as HTMLElement).style.width = '';
        (spans[1] as HTMLElement).style.transform = 'none';
        (spans[1] as HTMLElement).style.width = '';
      }
    }

    const handleScroll = () => {
      const currentNav = document.getElementById('main-nav');
      if (window.scrollY > 20) {
        currentNav?.classList.add('is-scrolled');
      } else {
        currentNav?.classList.remove('is-scrolled');
      }
    };

    (window as any).__ssNavInit = (window as any).__ssNavInit || {};
    
    if (!(window as any).__ssNavInit.scroll) {
      window.addEventListener('scroll', handleScroll);
      (window as any).__ssNavInit.scroll = true;
    }

    if (!(window as any).__ssNavInit.resize) {
      window.addEventListener('resize', () => {
        if (window.innerWidth >= 768) {
          const currentMenu = document.getElementById('mobile-menu');
          const currentOverlay = document.getElementById('nav-overlay');
          const currentToggle = document.getElementById('nav-toggle');
          
          currentMenu?.classList.remove('is-open');
          currentOverlay?.classList.remove('is-visible');
          document.body.style.overflow = '';
          currentToggle?.setAttribute('aria-expanded', 'false');
          
          const spans = currentToggle?.querySelectorAll('span');
          if (spans && spans.length > 1) {
            (spans[0] as HTMLElement).style.transform = 'none';
            (spans[0] as HTMLElement).style.width = '';
            (spans[1] as HTMLElement).style.transform = 'none';
            (spans[1] as HTMLElement).style.width = '';
          }
        }
      });
      (window as any).__ssNavInit.resize = true;
    }

    // Trigger scroll once on load to set initial state
    handleScroll();

    const mobileCloseBtn = document.getElementById('mobile-menu-close');
    mobileCloseBtn?.addEventListener('click', closeMenu);

    toggle?.addEventListener('click', () => {
      if (menu?.classList.contains('is-open')) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    overlay?.addEventListener('click', closeMenu);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  });
</script>
