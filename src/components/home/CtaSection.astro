---
import type { Locale } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';
import { buildWhatsAppUrl } from '../../lib/whatsapp';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="section">
  <div class="container container--narrow">
    <div class="cta-card reveal-scale">
      <div class="cta-content">
        <span class="section-eyebrow cta-eyebrow">{t('cta.eyebrow')}</span>
        <h2 class="cta-title">{t('cta.title')}</h2>
        <p class="cta-subtitle">{t('cta.subtitle')}</p>
        <div class="cta-actions">
          <a href={buildWhatsAppUrl(locale)} class="btn btn-whatsapp btn-lg" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
            </svg>
            {t('cta.primary')}
          </a>
          <a href={`/${locale}/menu`} class="btn btn-secondary btn-lg">{t('cta.secondary')}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-card {
    background: linear-gradient(135deg, var(--color-emerald-light) 0%, var(--color-emerald-dark) 100%);
    border-radius: var(--radius-2xl);
    padding: var(--space-12) var(--space-8);
    text-align: center;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }

  .cta-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  .cta-content {
    position: relative;
    z-index: var(--z-base);
  }

  .cta-eyebrow {
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-gold-pale);
    border-color: rgba(212, 175, 55, 0.3);
  }

  .cta-title {
    font-size: var(--text-4xl);
    color: var(--color-white);
    margin-bottom: var(--space-4);
  }

  .cta-subtitle {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: var(--space-8);
    max-width: 60ch;
    margin-inline: auto;
  }

  .cta-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-actions .btn-secondary {
    border-color: var(--color-white);
    color: var(--color-white);
  }

  .cta-actions .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 640px) {
    .cta-actions {
      flex-direction: column;
    }
  }
</style>
