---
import type { Locale } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';
import SectionHeading from '../common/SectionHeading.astro';
import type { LocalizedTestimonial } from '../../types/app';

export interface Props {
  locale: Locale;
  testimonials: LocalizedTestimonial[];
}

const { locale, testimonials } = Astro.props;
const t = useTranslations(locale);
---

<section class="section bg-ivory">
  <div class="container">
    <SectionHeading 
      eyebrow={t('testimonials.eyebrow')}
      title={t('testimonials.title')}
      subtitle={t('testimonials.subtitle')}
    />

    <div class="grid-3">
      {testimonials.map((item, index) => (
        <div class={`testimonial-card reveal stagger-${(index % 3) + 1}`}>
          <div class="testimonial-card__quote">"</div>
          <div class="testimonial-card__stars">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill={i < item.rating ? "currentColor" : "none"} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            ))}
          </div>
          <p class="testimonial-card__content">{item.content}</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">
              {item.customer_avatar_url ? (
                <img src={item.customer_avatar_url} alt={item.customer_name} loading="lazy" />
              ) : (
                <div class="testimonial-card__avatar-placeholder">
                  {item.customer_name.charAt(0).toUpperCase()}
                </div>
              )}
            </div>
            <div>
              <div class="testimonial-card__author-name">{item.customer_name}</div>
              {item.customer_title && <div class="testimonial-card__author-title">{item.customer_title}</div>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
