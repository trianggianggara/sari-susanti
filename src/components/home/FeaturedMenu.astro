---
import type { Locale } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';
import SectionHeading from '../common/SectionHeading.astro';
import type { LocalizedProduct } from '../../types/app';
import { formatPrice } from '../../lib/format';
import { buildWhatsAppUrl } from '../../lib/whatsapp';

export interface Props {
  locale: Locale;
  products: LocalizedProduct[];
}

const { locale, products } = Astro.props;
const t = useTranslations(locale);
const isEn = locale === 'en';
---

<section class="section bg-ivory">
  <div class="container">
    <SectionHeading 
      eyebrow={t('featured.eyebrow')}
      title={t('featured.title')}
      subtitle={t('featured.subtitle')}
    />

    <div class="grid-3">
      {products.map((product, index) => (
        <div class={`product-card reveal stagger-${(index % 3) + 1}`}>
          <a href={`/${locale}/menu/${product.slug}`} class="product-card__image skeleton-img-wrapper">
            {product.is_featured && <span class="product-card__badge">{t('menu.featured')}</span>}
            <img src={product.image_url || '/placeholder.jpg'} alt={isEn ? (product.name_en || product.name) : product.name} loading="lazy" />
          </a>
          <div class="product-card__body">
            <h3 class="product-card__name">
              <a href={`/${locale}/menu/${product.slug}`}>{isEn ? (product.name_en || product.name) : product.name}</a>
            </h3>
            <p class="product-card__desc">{isEn ? (product.short_description_en || product.short_description) : product.short_description}</p>
            <div class="product-card__footer">
              <div class="product-card__price">
                <span class="product-card__price-label">{t('menu.price_from')}</span>
                <span class="product-card__price-value">{formatPrice(product.price, locale)}</span>
              </div>
              <div class="product-card__actions">
                <button
                  class="btn btn--outline btn--sm btn-add-cart"
                  data-slug={product.slug}
                  data-name={isEn ? (product.name_en || product.name) : product.name}
                  data-price={product.price ?? ''}
                  data-image={product.image_url || ''}
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="9" cy="21" r="1"></circle>
                    <circle cx="20" cy="21" r="1"></circle>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                  </svg>
                  {isEn ? 'Add' : 'Tambah'}
                </button>
                <a
                  href={buildWhatsAppUrl(locale, isEn ? (product.name_en || product.name) : product.name)}
                  class="btn btn--primary btn--sm"
                  target="_blank" rel="noopener noreferrer"
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  {isEn ? 'Order' : 'Pesan'}
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="featured-actions reveal">
      <a href={`/${locale}/menu`} class="btn btn-secondary btn-lg">{t('featured.cta')}</a>
    </div>
  </div>
</section>

<script>
  interface CartItem { slug: string; name: string; price: number | null; image: string; qty: number; }
  const CART_KEY = 'ss_cart';
  const CART_EVENT = 'ss:cart-updated';
  function getItems(): CartItem[] { try { return JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch { return []; } }
  function saveItems(items: CartItem[]): void {
    localStorage.setItem(CART_KEY, JSON.stringify(items));
    window.dispatchEvent(new CustomEvent(CART_EVENT, { detail: items }));
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as Element | null)?.closest('.btn-add-cart') as HTMLButtonElement | null;
    if (!btn) return;

    const { slug, name, price, image } = btn.dataset;
    const items = getItems();
    const existing = items.find((i: CartItem) => i.slug === slug);
    if (existing) {
      existing.qty += 1;
    } else {
      items.push({ slug: slug ?? '', name: name ?? '', price: price ? Number(price) : null, image: image ?? '', qty: 1 });
    }
    saveItems(items);

    // Visual feedback
    const original = btn.innerHTML;
    btn.innerHTML = '✓ ' + (document.documentElement.lang === 'en' ? 'Added!' : 'Ditambahkan!');
    btn.disabled = true;
    setTimeout(() => { btn.innerHTML = original; btn.disabled = false; }, 1200);

    // Open cart drawer
    window.dispatchEvent(new CustomEvent('ss:open-cart'));
  });
</script>

<style>
  .featured-actions {
    display: flex;
    justify-content: center;
    margin-top: var(--space-12);
  }
</style>
