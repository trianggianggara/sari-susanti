---
import type { Locale } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';
import { CONTACT_LINKS } from '../../lib/constants';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="hero">
  <div class="hero__bg">
    <img src="https://images.unsplash.com/photo-1555244162-803834f70033?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" alt="Sari Susanti Premium Catering" class="hero__img" />
    <div class="hero__overlay bg-grain"></div>
  </div>

  <div class="container hero__content hero-animate">
    <div class="hero__badge badge badge-gold hero-badge" style="animation: fadeDown 0.8s var(--ease-out) 0.1s both;">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
      </svg>
      {t('hero.badge')}
    </div>
    
    <h1 class="hero__title hero-heading gradient-text">Sari Susanti</h1>
    <p class="hero__subtitle hero-subheading">{t('footer.tagline')}</p>
    
    <div class="hero__actions hero-cta">
      <a href={`/${locale}/menu`} class="hero-btn hero-btn--primary hover-lift">{t('hero.cta.primary')}</a>
      
      <a href={CONTACT_LINKS.whatsapp} class="hero-link--whatsapp" target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="wa-icon">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
        </svg>
        {t('hero.cta.secondary')}
      </a>
    </div>
  </div>

  <div class="hero__scroll">
    <span>{t('hero.scroll')}</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    margin-top: calc(var(--nav-height) * -1);
    padding-top: var(--nav-height);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: var(--z-below);
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.5); /* brightened slightly for more vibrancy */
    transform: scale(1.05);
    animation: slow-zoom 20s linear infinite alternate;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(20, 30, 15, 0.7) 0%,
      rgba(45, 90, 39, 0.2) 40%,
      var(--color-ivory) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: var(--z-base);
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 800px;
  }

  .hero__badge {
    margin-bottom: var(--space-6);
  }

  .hero__title {
    font-size: var(--text-hero);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-4);
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }

  .hero__subtitle {
    font-family: var(--font-accent);
    font-style: italic;
    font-size: var(--text-2xl);
    color: var(--color-white);
    margin-bottom: var(--space-10);
    opacity: 0.95;
  }

  .hero__actions {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-2);
  }

  /* --- Premium Pill Buttons --- */
  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--space-8);
    height: 54px;
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    border-radius: var(--radius-full); /* Beautiful pill shape */
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-out);
    position: relative;
    overflow: hidden;
  }

  .hero-btn--primary {
    background: var(--color-gold);
    color: var(--color-emerald-dark);
    box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
  }
  .hero-btn--primary:hover {
    background: var(--color-gold-light);
    box-shadow: 0 6px 20px rgba(212, 175, 55, 0.4);
    transform: translateY(-2px);
  }

  .hero-btn--whatsapp {
    background: var(--color-emerald);
    color: var(--color-white);
    box-shadow: 0 4px 15px rgba(45, 90, 39, 0.3);
    gap: var(--space-2); /* Space for icon */
  }
  
  .hero-btn--whatsapp:hover {
    background: var(--color-emerald-light);
    box-shadow: 0 6px 20px rgba(45, 90, 39, 0.4);
    transform: translateY(-2px);
  }

  .hero-link--whatsapp {
    color: var(--color-emerald);
    text-decoration: none;
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    position: relative;
    padding: var(--space-2) 0;
    margin-left: var(--space-4);
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .wa-icon {
    transition: transform var(--duration-fast) var(--ease-out);
  }
  .hero-btn--whatsapp:hover .wa-icon {
    transform: scale(1.1) rotate(-5deg);
  }

  .hero-link--whatsapp::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-emerald); /* Strict brand.md Emerald */
    transition: width var(--duration-normal) var(--ease-out);
  }

  .hero-link--whatsapp:hover::after {
    width: 100%;
  }

  .hero-link--whatsapp:hover {
    opacity: 0.9;
  }

  .hero-link--whatsapp:hover .wa-icon {
    transform: scale(1.1) rotate(-5deg);
  }

  .hero__scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-emerald);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: var(--color-emerald);
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: var(--color-gold);
    animation: scroll-drop 2s ease-in-out infinite;
  }

  @keyframes slow-zoom {
    from { transform: scale(1.05); }
    to { transform: scale(1.15); }
  }

  @keyframes scroll-drop {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }

  @media (max-width: 640px) {
    .hero__actions { flex-direction: column; width: 100%; gap: var(--space-3); }
    .hero__actions .hero-btn { width: 100%; }
  }
</style>


