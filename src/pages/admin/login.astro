---
import BaseHead from '../../components/common/BaseHead.astro';
import LoginForm from '../../components/admin/LoginForm';

export const prerender = false;
---

<!doctype html>
<html lang="id">
  <head>
    <BaseHead locale="id" title="Admin Login — Sari Susanti" description="Masuk ke panel administrasi Sari Susanti" />
  </head>
  <body class="login-page-body">
    <LoginForm client:load />
  </body>
</html>

<style is:global>
  /* ── Reset for login page ── */
  .login-page-body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    background: var(--color-ivory-warm);
    font-family: var(--font-body);
  }

  /* ════════════════════════════════════════════════
     LOGIN ROOT — split layout
  ════════════════════════════════════════════════ */
  .login-root {
    display: flex;
    min-height: 100vh;
  }

  /* ── Left decorative panel ── */
  .login-panel {
    display: none; /* hidden on mobile */
    position: relative;
    width: 42%;
    flex-shrink: 0;
    background: var(--color-emerald-dark);
    overflow: hidden;
  }

  @media (min-width: 900px) {
    .login-panel { display: flex; align-items: center; }
  }

  /* Animated orbs */
  .login-panel__orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .login-panel__orb--1 {
    width: 440px;
    height: 440px;
    top: -120px;
    right: -140px;
    background: radial-gradient(circle, rgba(61, 122, 53, 0.55) 0%, transparent 70%);
    animation: orbFloat 9s ease-in-out infinite;
  }

  .login-panel__orb--2 {
    width: 300px;
    height: 300px;
    bottom: -80px;
    left: -80px;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.18) 0%, transparent 70%);
    animation: orbFloat 12s ease-in-out infinite reverse;
  }

  .login-panel__orb--3 {
    width: 180px;
    height: 180px;
    top: 55%;
    left: 55%;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.12) 0%, transparent 70%);
    animation: orbFloat 7s ease-in-out infinite 2s;
  }

  @keyframes orbFloat {
    0%, 100% { transform: translateY(0) scale(1); }
    50%       { transform: translateY(-24px) scale(1.04); }
  }

  .login-panel__content {
    position: relative;
    z-index: 2;
    padding: 3rem 3rem 3rem 3.5rem;
    width: 100%;
  }

  .login-panel__logo-mark {
    height: 100px;
    width: auto;
    max-width: 240px;
    object-fit: contain;
    margin-bottom: 1.5rem;
    animation: loginLogoIn 0.7s var(--ease-spring) both;
  }

  .login-panel__brand {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 2.5vw, 2.4rem);
    font-weight: 600;
    color: var(--color-ivory);
    margin: 0 0 0.25rem;
    animation: loginSlideUp 0.7s var(--ease-smooth) 0.1s both;
  }

  .login-panel__tagline {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 2rem;
    animation: loginSlideUp 0.7s var(--ease-smooth) 0.15s both;
  }

  .login-panel__divider {
    width: 40px;
    height: 2px;
    background: linear-gradient(to right, var(--color-gold), transparent);
    border-radius: var(--radius-full);
    margin-bottom: 1.5rem;
    animation: loginSlideUp 0.6s var(--ease-smooth) 0.2s both;
  }

  .login-panel__quote {
    font-family: var(--font-accent);
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.55);
    margin: 0 0 2.5rem;
    max-width: 30ch;
    animation: loginSlideUp 0.7s var(--ease-smooth) 0.25s both;
  }

  .login-panel__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .login-panel__feature-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    font-weight: 500;
    animation: loginSlideUp 0.6s var(--ease-smooth) both;
  }

  .login-panel__feature-item:nth-child(1) { animation-delay: 0.3s; }
  .login-panel__feature-item:nth-child(2) { animation-delay: 0.38s; }
  .login-panel__feature-item:nth-child(3) { animation-delay: 0.46s; }
  .login-panel__feature-item:nth-child(4) { animation-delay: 0.54s; }

  .login-panel__feature-item svg {
    flex-shrink: 0;
    color: var(--color-gold);
  }

  /* ── Right form panel ── */
  .login-form-panel {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    background: var(--color-ivory-warm);
  }

  .login-form-wrap {
    width: 100%;
    max-width: 420px;
    animation: loginFormIn 0.65s var(--ease-spring) 0.15s both;
  }

  /* Mobile-only brand header */
  .login-mobile-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 900px) {
    .login-mobile-brand { display: none; }
  }

  .login-mobile-brand__mark {
    height: 64px;
    width: auto;
    max-width: 180px;
    object-fit: contain;
  }

  .login-mobile-brand__name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-emerald-dark);
    margin: 0;
    max-width: none;
  }

  .login-mobile-brand__sub {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold-dark);
    margin: 0;
    max-width: none;
  }

  .login-form-header { margin-bottom: 2rem; }

  .login-form-title {
    font-family: var(--font-display);
    font-size: 1.85rem;
    color: var(--color-emerald-dark);
    margin: 0 0 0.375rem;
    font-weight: 600;
  }

  .login-form-sub {
    font-size: 0.875rem;
    color: var(--color-stone);
    margin: 0;
    max-width: none;
  }

  .login-error {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(196,69,54,0.08);
    border: 1.5px solid rgba(196,69,54,0.22);
    color: var(--color-error);
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    animation: loginShake 0.4s var(--ease-out);
  }

  @keyframes loginShake {
    0%, 100% { transform: translateX(0); }
    20%       { transform: translateX(-6px); }
    40%       { transform: translateX(6px); }
    60%       { transform: translateX(-4px); }
    80%       { transform: translateX(4px); }
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .login-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .login-label {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-charcoal);
    letter-spacing: 0.02em;
  }

  .login-label svg { color: var(--color-stone); }

  .login-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--color-sand);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-charcoal);
    background: var(--color-white);
    outline: none;
    box-sizing: border-box;
    transition: border-color 150ms var(--ease-out), box-shadow 150ms var(--ease-out);
    box-shadow: var(--shadow-xs);
  }

  .login-input:focus {
    border-color: var(--color-emerald);
    box-shadow: 0 0 0 3px var(--color-emerald-glass);
  }

  .login-input--password { padding-right: 3rem; }

  .login-input-wrap { position: relative; }

  .login-toggle-pass {
    position: absolute;
    right: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--color-stone);
    cursor: pointer;
    display: flex;
    align-items: center;
    padding: 0.25rem;
    border-radius: var(--radius-sm);
    transition: color 150ms;
  }

  .login-toggle-pass:hover { color: var(--color-emerald); }

  .login-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.875rem 1.5rem;
    background: linear-gradient(135deg, var(--color-emerald) 0%, var(--color-emerald-dark) 100%);
    color: var(--color-white);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    box-shadow: var(--shadow-emerald);
    transition: all 200ms var(--ease-out);
    margin-top: 0.5rem;
    position: relative;
    overflow: hidden;
  }

  .login-submit::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 60%);
    pointer-events: none;
  }

  .login-submit:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(45,90,39,0.35);
  }

  .login-submit:active:not(:disabled) {
    transform: translateY(0);
  }

  .login-submit--loading,
  .login-submit:disabled {
    opacity: 0.75;
    cursor: not-allowed;
    transform: none;
  }

  /* Spinner */
  .login-spinner {
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255,255,255,0.35);
    border-top-color: var(--color-white);
    border-radius: 50%;
    animation: loginSpin 0.7s linear infinite;
    flex-shrink: 0;
  }

  @keyframes loginSpin {
    to { transform: rotate(360deg); }
  }

  .login-footer-note {
    margin-top: 1.75rem;
    font-size: 0.75rem;
    color: var(--color-stone-light);
    text-align: center;
    max-width: none;
  }

  /* ── Entrance animations ── */
  @keyframes loginLogoIn {
    from { opacity: 0; transform: scale(0.7) rotate(-8deg); }
    to   { opacity: 1; transform: scale(1) rotate(0); }
  }

  @keyframes loginSlideUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes loginFormIn {
    from { opacity: 0; transform: translateY(28px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
</style>
