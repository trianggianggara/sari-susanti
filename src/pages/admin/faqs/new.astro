---
import AdminLayout from '../../../layouts/AdminLayout.astro';

export const prerender = false;
---

<AdminLayout title="Tambah FAQ">
  <div class="max-w-[800px] bg-white p-6 rounded-lg border border-sand shadow-brand-sm">
    <h2 class="mt-0 mb-6 text-emerald-dark font-display text-2xl">FAQ Baru</h2>
    
    <form id="faq-form" method="POST">
      <div class="mb-4">
        <label class="block mb-2 font-semibold text-sm text-charcoal">Grup Kategori FAQ</label>
        <input type="text" name="category" placeholder="Contoh: Pemesanan, Pengiriman, dll" class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-charcoal">Pertanyaan (ID) *</label>
          <textarea name="question" rows="2" required class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none"></textarea>
        </div>
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-charcoal">Pertanyaan (EN)</label>
          <textarea name="question_en" rows="2" class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none"></textarea>
        </div>
      </div>

      <div class="mb-4">
        <label class="block mb-2 font-semibold text-sm text-charcoal">Jawaban (ID) *</label>
        <textarea name="answer" rows="5" required class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none"></textarea>
      </div>

      <div class="mb-4">
        <label class="block mb-2 font-semibold text-sm text-charcoal">Jawaban (EN)</label>
        <textarea name="answer_en" rows="5" class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none"></textarea>
      </div>

      <div class="mb-6">
        <label class="flex items-center gap-2 font-semibold text-sm text-charcoal cursor-pointer">
          <input type="checkbox" name="is_active" checked class="w-4 h-4 text-emerald-dark accent-emerald-dark" />
          Publish (Tampilkan di website)
        </label>
      </div>

      <div class="mb-6 w-[200px]">
        <label class="block mb-2 font-semibold text-sm text-charcoal">Urutan (Sort Order)</label>
        <input type="number" name="sort_order" value="0" class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
      </div>

      <div class="flex gap-4">
        <button type="submit" class="bg-emerald-dark text-white border-none py-3 px-6 rounded-md font-bold cursor-pointer transition-colors hover:bg-emerald-light shadow-brand-sm">Simpan FAQ</button>
        <a href="/admin/faqs" class="inline-block py-3 px-6 text-charcoal no-underline border border-sand rounded-md font-bold transition-colors hover:bg-ivory-warm">Batal</a>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  import { showToast } from '@/lib/admin-toast';

  const form = document.getElementById('faq-form') as HTMLFormElement;
  const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

  form.addEventListener('submit', async (e: SubmitEvent) => {
    e.preventDefault();

    const fd = new FormData(form);
    const question = (fd.get('question') as string)?.trim();
    const answer = (fd.get('answer') as string)?.trim();

    if (!question || !answer) {
      showToast('Pertanyaan dan Jawaban wajib diisi.', 'error');
      return;
    }

    submitBtn.disabled = true;
    const originalText = submitBtn.textContent || 'Simpan FAQ';
    submitBtn.textContent = 'Menyimpan…';

    try {
      const res = await fetch('/api/admin/faqs', { method: 'POST', body: fd });
      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || 'Gagal menyimpan FAQ.');
      }

      showToast('FAQ berhasil ditambahkan.', 'success');
      setTimeout(() => { window.location.href = '/admin/faqs'; }, 800);
    } catch (err) {
      showToast(err instanceof Error ? err.message : 'Terjadi kesalahan.', 'error');
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
