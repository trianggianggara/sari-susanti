---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import AdminDeleteButton from '../../../components/admin/AdminDeleteButton.astro';

export const prerender = false;

const { supabase } = Astro.locals;
const { data: faqs, error } = await supabase
  .from('faqs')
  .select('*')
  .order('sort_order', { ascending: true });

if (error) {
  console.error(error);
}

// Handle Delete
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const id = formData.get('id');
  if (id) {
    await supabase.from('faqs').delete().eq('id', id);
    return Astro.redirect('/admin/faqs');
  }
}
---

<AdminLayout title="Kelola FAQ">
  <div class="flex justify-between items-center mb-6">
    <h2 class="m-0 font-display text-emerald-dark text-2xl">Daftar FAQ</h2>
    <a href="/admin/faqs/new" class="bg-emerald-dark text-white px-4 py-2 no-underline rounded-md font-bold transition-colors duration-150 ease-out hover:bg-emerald-light shadow-brand-sm hover:shadow-brand-md">+ Tambah FAQ</a>
  </div>

  <div class="bg-white rounded-lg border border-sand overflow-hidden shadow-brand-sm">
    <table class="w-full border-collapse text-left">
      <thead class="bg-ivory-warm border-b border-sand">
        <tr>
          <th class="p-4 text-charcoal-light font-semibold text-sm">Pertanyaan</th>
          <th class="p-4 text-charcoal-light font-semibold text-sm">Kategori</th>
          <th class="p-4 text-charcoal-light font-semibold text-sm">Status</th>
          <th class="p-4 text-charcoal-light font-semibold text-sm text-right">Aksi</th>
        </tr>
      </thead>
      <tbody>
        {faqs?.map((faq) => (
          <tr class="border-b border-sand transition-colors hover:bg-ivory">
            <td class="p-4 font-bold text-charcoal">{faq.question}</td>
            <td class="p-4 text-charcoal">{faq.category || '-'}</td>
            <td class="p-4">
              <span class={`px-3 py-1 rounded-full text-xs font-bold ${faq.is_active ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
                {faq.is_active ? 'Publish' : 'Draft'}
              </span>
            </td>
            <td class="p-4 text-right">
              <div class="flex justify-end gap-3 items-center">
                <a href={`/admin/faqs/${faq.id}`} class="text-blue-600 font-bold no-underline transition-opacity hover:opacity-70">Edit</a>
                <AdminDeleteButton 
                  id={faq.id} 
                  itemName="FAQ ini" 
                  confirmMessage="Yakin ingin menghapus FAQ ini? Tindakan ini tidak dapat dibatalkan."
                  successMessage="FAQ berhasil dihapus"
                />
              </div>
            </td>
          </tr>
        ))}
        {faqs?.length === 0 && (
          <tr>
            <td colspan="4" class="p-6 text-center text-charcoal-light">Belum ada FAQ.</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>
