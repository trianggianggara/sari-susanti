---
import AdminLayout from '../../../layouts/AdminLayout.astro';

export const prerender = false;

const { id } = Astro.params;
const { supabase } = Astro.locals;

// Fetch testimonial
const { data: testimonial, error: fetchError } = await supabase
  .from('testimonials')
  .select('*')
  .eq('id', id)
  .single();

if (fetchError || !testimonial) {
  return Astro.redirect('/admin/testimonials');
}
---

<AdminLayout title="Edit Testimoni">
  <div class="max-w-[800px] bg-white p-6 rounded-lg border border-sand shadow-brand-sm">
    <h2 class="mt-0 mb-6 text-emerald-dark font-display text-2xl">Edit Testimoni</h2>
    
    <form id="testimonial-form" data-id={testimonial.id} method="POST" enctype="multipart/form-data">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-charcoal">Nama Pelanggan *</label>
          <input type="text" name="customer_name" value={testimonial.customer_name} required class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
        </div>
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-charcoal">Jabatan / Lokasi</label>
          <input type="text" name="customer_role" value={testimonial.customer_role || ''} class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-charcoal">Rating (1-5) *</label>
          <input type="number" name="rating" min="1" max="5" value={testimonial.rating} required class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
        </div>
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-charcoal">Jenis Acara</label>
          <input type="text" name="event_type" value={testimonial.event_type || ''} class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
        </div>
      </div>

      <div class="mb-4">
        <label class="block mb-2 font-semibold text-sm text-charcoal">Isi Testimoni (ID) *</label>
        <textarea name="content" rows="4" required class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none">{testimonial.content}</textarea>
      </div>

      <div class="mb-4">
        <label class="block mb-2 font-semibold text-sm text-charcoal">Isi Testimoni (EN)</label>
        <textarea name="content_en" rows="4" class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none">{testimonial.content_en || ''}</textarea>
      </div>

      <div class="mb-4">
        <label class="block mb-2 font-semibold text-sm text-charcoal">Foto Pelanggan</label>
        {testimonial.customer_image_url && (
          <div class="mb-4">
            <img src={testimonial.customer_image_url} alt="Current" class="w-[100px] rounded-full border border-sand shadow-sm" />
          </div>
        )}
        <input type="file" name="image" accept="image/*" class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none bg-white" />
        <small class="text-stone text-xs mt-1 block">Biarkan kosong jika tidak ingin mengubah gambar.</small>
      </div>

      <div class="flex gap-8 mb-6">
        <label class="flex items-center gap-2 font-semibold text-sm text-charcoal cursor-pointer">
          <input type="checkbox" name="is_active" checked={testimonial.is_active} class="w-4 h-4 text-emerald-dark accent-emerald-dark" />
          Publish (Tampilkan)
        </label>
        <label class="flex items-center gap-2 font-semibold text-sm text-charcoal cursor-pointer">
          <input type="checkbox" name="is_featured" checked={testimonial.is_featured} class="w-4 h-4 text-emerald-dark accent-emerald-dark" />
          Featured (Tampil di Beranda)
        </label>
      </div>

      <div class="mb-6 w-[200px]">
        <label class="block mb-2 font-semibold text-sm text-charcoal">Urutan (Sort Order)</label>
        <input type="number" name="sort_order" value={testimonial.sort_order} class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
      </div>

      <div class="flex gap-4">
        <button type="submit" class="bg-emerald-dark text-white border-none py-3 px-6 rounded-md font-bold cursor-pointer transition-colors hover:bg-emerald-light shadow-brand-sm">Update Testimoni</button>
        <a href="/admin/testimonials" class="inline-block py-3 px-6 text-charcoal no-underline border border-sand rounded-md font-bold transition-colors hover:bg-ivory-warm">Batal</a>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  import { showToast } from '@/lib/admin-toast';

  const form = document.getElementById('testimonial-form') as HTMLFormElement;
  const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

  form.addEventListener('submit', async (e: SubmitEvent) => {
    e.preventDefault();

    const fd = new FormData(form);
    const customer_name = (fd.get('customer_name') as string)?.trim();
    const content = (fd.get('content') as string)?.trim();

    if (!customer_name || !content) {
      showToast('Nama pelanggan dan isi testimoni wajib diisi.', 'error');
      return;
    }

    submitBtn.disabled = true;
    const originalText = submitBtn.textContent || 'Update Testimoni';
    submitBtn.textContent = 'Menyimpan…';

    try {
      const res = await fetch(`/api/admin/testimonials/${form.dataset.id}`, { method: 'POST', body: fd });
      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || 'Gagal memperbarui testimoni.');
      }

      showToast('Testimoni berhasil diperbarui.', 'success');
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    } catch (err) {
      showToast(err instanceof Error ? err.message : 'Terjadi kesalahan.', 'error');
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
