---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import AdminDeleteButton from '../../../components/admin/AdminDeleteButton.astro';

export const prerender = false;

const { supabase } = Astro.locals;
const { data: testimonials, error } = await supabase
  .from('testimonials')
  .select('*')
  .order('sort_order', { ascending: true });

if (error) {
  console.error(error);
}

// Handle Delete
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const id = formData.get('id');
  if (id) {
    await supabase.from('testimonials').delete().eq('id', id);
    return Astro.redirect('/admin/testimonials');
  }
}
---

<AdminLayout title="Kelola Testimoni">
  <div class="flex justify-between items-center mb-6">
    <h2 class="m-0 font-display text-emerald-dark text-2xl">Daftar Testimoni</h2>
    <a href="/admin/testimonials/new" class="bg-emerald-dark text-white px-4 py-2 no-underline rounded-md font-bold transition-colors duration-150 ease-out hover:bg-emerald-light shadow-brand-sm hover:shadow-brand-md">+ Tambah Testimoni</a>
  </div>

  <div class="bg-white rounded-lg border border-sand overflow-hidden shadow-brand-sm">
    <table class="w-full border-collapse text-left">
      <thead class="bg-ivory-warm border-b border-sand">
        <tr>
          <th class="p-4 text-charcoal-light font-semibold text-sm">Foto</th>
          <th class="p-4 text-charcoal-light font-semibold text-sm">Pelanggan</th>
          <th class="p-4 text-charcoal-light font-semibold text-sm">Rating</th>
          <th class="p-4 text-charcoal-light font-semibold text-sm">Status</th>
          <th class="p-4 text-charcoal-light font-semibold text-sm text-right">Aksi</th>
        </tr>
      </thead>
      <tbody>
        {testimonials?.map((t) => (
          <tr class="border-b border-sand transition-colors hover:bg-ivory">
            <td class="p-4">
              {t.customer_image_url ? (
                <img src={t.customer_image_url} alt={t.customer_name} class="w-[50px] h-[50px] object-cover rounded-full shadow-sm border border-sand" />
              ) : (
                <div class="w-[50px] h-[50px] bg-gray-100 rounded-full border border-sand"></div>
              )}
            </td>
            <td class="p-4">
              <div class="font-bold text-charcoal">{t.customer_name}</div>
              <div class="text-xs text-charcoal-light mt-1">{t.customer_role || '-'}</div>
            </td>
            <td class="p-4">
              <span class="text-gold">{'★'.repeat(t.rating)}</span>
              <span class="text-gray-300">{'★'.repeat(5 - t.rating)}</span>
            </td>
            <td class="p-4">
              <span class={`px-3 py-1 rounded-full text-xs font-bold ${t.is_active ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
                {t.is_active ? 'Publish' : 'Draft'}
              </span>
            </td>
            <td class="p-4 text-right">
              <div class="flex justify-end gap-3 items-center h-[50px]">
                <a href={`/admin/testimonials/${t.id}`} class="text-blue-600 font-bold no-underline transition-opacity hover:opacity-70">Edit</a>
                <AdminDeleteButton 
                  id={t.id} 
                  itemName={t.customer_name} 
                  confirmMessage={`Yakin ingin menghapus testimoni dari "${t.customer_name}"? Tindakan ini tidak dapat dibatalkan.`}
                  successMessage={`Testimoni dari "${t.customer_name}" berhasil dihapus`}
                />
              </div>
            </td>
          </tr>
        ))}
        {testimonials?.length === 0 && (
          <tr>
            <td colspan="5" class="p-6 text-center text-charcoal-light">Belum ada testimoni.</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>
