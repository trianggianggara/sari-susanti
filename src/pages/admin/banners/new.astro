---
import AdminLayout from '../../../layouts/AdminLayout.astro';

export const prerender = false;
---

<AdminLayout title="Tambah Banner">
  <div class="max-w-[800px] bg-white p-6 rounded-lg border border-sand shadow-brand-sm">
    <h2 class="mt-0 mb-6 text-emerald-dark font-display text-2xl">Banner Baru</h2>
    
    <form id="banner-form" method="POST" enctype="multipart/form-data">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-charcoal">Judul (ID) *</label>
          <input type="text" name="title" required class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
        </div>
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-charcoal">Judul (EN)</label>
          <input type="text" name="title_en" class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-charcoal">Subtitle (ID)</label>
          <input type="text" name="subtitle" class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
        </div>
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-charcoal">Subtitle (EN)</label>
          <input type="text" name="subtitle_en" class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-charcoal">Teks Tombol CTA (ID)</label>
          <input type="text" name="cta_text" placeholder="Pesan Sekarang" class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
        </div>
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-charcoal">Teks Tombol CTA (EN)</label>
          <input type="text" name="cta_text_en" placeholder="Order Now" class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
        </div>
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-charcoal">Link CTA</label>
          <input type="text" name="cta_link" placeholder="/menu" class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
        </div>
      </div>

      <div class="mb-4">
        <label class="block mb-2 font-semibold text-sm text-charcoal">Gambar Banner *</label>
        <input type="file" name="image" accept="image/*" required class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none bg-white" />
      </div>

      <div class="mb-6">
        <label class="flex items-center gap-2 font-semibold text-sm text-charcoal cursor-pointer">
          <input type="checkbox" name="is_active" checked class="w-4 h-4 text-emerald-dark accent-emerald-dark" />
          Aktif (Tampilkan di beranda)
        </label>
      </div>

      <div class="mb-6 w-[200px]">
        <label class="block mb-2 font-semibold text-sm text-charcoal">Urutan (Sort Order)</label>
        <input type="number" name="sort_order" value="0" class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none" />
      </div>

      <div class="flex gap-4">
        <button type="submit" class="bg-emerald-dark text-white border-none py-3 px-6 rounded-md font-bold cursor-pointer transition-colors hover:bg-emerald-light shadow-brand-sm">Simpan Banner</button>
        <a href="/admin/banners" class="inline-block py-3 px-6 text-charcoal no-underline border border-sand rounded-md font-bold transition-colors hover:bg-ivory-warm">Batal</a>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  import { showToast } from '@/lib/admin-toast';

  const form = document.getElementById('banner-form') as HTMLFormElement;
  const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

  form.addEventListener('submit', async (e: SubmitEvent) => {
    e.preventDefault();

    const fd = new FormData(form);
    const title = (fd.get('title') as string)?.trim();
    const image = fd.get('image') as File;

    if (!title) {
      showToast('Judul wajib diisi.', 'error');
      return;
    }
    if (!image || image.size === 0) {
      showToast('Gambar banner wajib diunggah.', 'error');
      return;
    }

    submitBtn.disabled = true;
    const originalText = submitBtn.textContent || 'Simpan Banner';
    submitBtn.textContent = 'Menyimpan…';

    try {
      const res = await fetch('/api/admin/banners', { method: 'POST', body: fd });
      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || 'Gagal menyimpan banner.');
      }

      showToast('Banner berhasil ditambahkan.', 'success');
      setTimeout(() => { window.location.href = '/admin/banners'; }, 800);
    } catch (err) {
      showToast(err instanceof Error ? err.message : 'Terjadi kesalahan.', 'error');
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
