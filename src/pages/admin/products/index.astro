---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import AdminDeleteButton from '../../../components/admin/AdminDeleteButton.astro';

export const prerender = false;

const { supabase } = Astro.locals;

// Handle delete (fallback for non-JS)
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const id = formData.get('id');
  if (id) {
    await supabase.from('products').delete().eq('id', id);
    return Astro.redirect('/admin/products?success=' + encodeURIComponent('Produk berhasil dihapus'));
  }
}

const { data: products, error } = await supabase
  .from('products')
  .select('*, categories(name)')
  .order('sort_order', { ascending: true });

if (error) console.error(error);
---

<AdminLayout title="Kelola Produk">

  <!-- Page header -->
  <div class="prod-list-header">
    <div>
      <h2 class="prod-list-title">Daftar Produk</h2>
      <p class="prod-list-subtitle">{products?.length ?? 0} produk terdaftar</p>
    </div>
    <a href="/admin/products/new" class="prod-add-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Tambah Produk
    </a>
  </div>

  <!-- Products table -->
  <div class="prod-table-wrap">
    <table class="prod-table" id="products-table">
      <thead>
        <tr>
          <th class="prod-th" style="width:64px">Foto</th>
          <th class="prod-th">Nama Produk</th>
          <th class="prod-th">Kategori</th>
          <th class="prod-th">Harga</th>
          <th class="prod-th">Status</th>
          <th class="prod-th prod-th--right">Aksi</th>
        </tr>
      </thead>
      <tbody id="products-tbody">
        {products?.map((prod) => (
          <tr class="prod-row" data-product-id={prod.id}>
            <td class="prod-td prod-td--img">
              {prod.image_url ? (
                <img
                  src={prod.image_url}
                  alt={prod.name}
                  class="prod-thumb"
                  loading="lazy"
                  width="48"
                  height="48"
                />
              ) : (
                <div class="prod-thumb-placeholder" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>
              )}
            </td>
            <td class="prod-td">
              <span class="prod-name">{prod.name}</span>
              {prod.is_featured && (
                <span class="prod-badge-featured" aria-label="Featured">Featured</span>
              )}
            </td>
            <td class="prod-td prod-td--muted">{prod.categories?.name ?? '—'}</td>
            <td class="prod-td prod-td--price">
              Rp {prod.price?.toLocaleString('id-ID') ?? '0'}
            </td>
            <td class="prod-td">
              <span class={`prod-status ${prod.is_active ? 'prod-status--active' : 'prod-status--inactive'}`}>
                {prod.is_active ? 'Tersedia' : 'Habis'}
              </span>
            </td>
            <td class="prod-td prod-td--actions">
              <div class="flex justify-end gap-3 items-center">
                <a href={`/admin/products/${prod.id}`} class="prod-action-edit" aria-label={`Edit ${prod.name}`}>
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                  </svg>
                  Edit
                </a>
                <AdminDeleteButton id={prod.id} itemName={prod.name}>
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                    <path d="M10 11v6M14 11v6"/>
                    <path d="M9 6V4h6v2"/>
                  </svg>
                  Hapus
                </AdminDeleteButton>
              </div>
            </td>
          </tr>
        ))}

        {(!products || products.length === 0) && (
          <tr>
            <td colspan="6" class="prod-empty">
              <div class="prod-empty__inner">
                <span aria-hidden="true" style="font-size:2.5rem">📦</span>
                <p>Belum ada produk. <a href="/admin/products/new">Tambah produk pertama</a>.</p>
              </div>
            </td>
          </tr>
        )}
      </tbody>
    </table>
  </div>

</AdminLayout>

<style>
  .prod-list-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .prod-list-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--color-emerald-dark);
    margin: 0 0 0.2rem;
  }

  .prod-list-subtitle {
    font-size: 0.825rem;
    color: var(--color-stone);
    margin: 0;
    max-width: none;
  }

  .prod-add-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-emerald-dark);
    color: var(--color-white);
    padding: 0.6rem 1.1rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: all 150ms var(--ease-out);
  }

  .prod-add-btn:hover {
    background: var(--color-emerald-light);
    box-shadow: var(--shadow-emerald);
    transform: translateY(-1px);
  }

  .prod-table-wrap {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-sand);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .prod-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .prod-th {
    padding: 0.875rem 1rem;
    text-align: left;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-stone);
    background: var(--color-ivory-warm);
    border-bottom: 1px solid var(--color-sand);
    white-space: nowrap;
  }

  .prod-th--right { text-align: right; }

  .prod-row {
    transition: background 100ms var(--ease-out);
  }

  .prod-row:hover { background: var(--color-ivory); }
  .prod-row:not(:last-child) { border-bottom: 1px solid var(--color-sand); }

  .prod-td {
    padding: 0.875rem 1rem;
    color: var(--color-charcoal);
    vertical-align: middle;
  }

  .prod-td--img { width: 64px; }
  .prod-td--muted { color: var(--color-stone); }
  .prod-td--price { font-weight: 600; color: var(--color-emerald); font-size: 0.9rem; white-space: nowrap; }
  .prod-td--actions {
    text-align: right;
    white-space: nowrap;
  }

  .prod-thumb {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    object-fit: cover;
    border: 1px solid var(--color-sand);
  }

  .prod-thumb-placeholder {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--color-ivory-deeper);
    border: 1px solid var(--color-sand);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-stone-light);
  }

  .prod-name {
    font-weight: 600;
    color: var(--color-charcoal);
    display: block;
    max-width: 240px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .prod-badge-featured {
    display: inline-block;
    margin-top: 0.2rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-gold);
    color: var(--color-emerald-dark);
    padding: 2px 7px;
    border-radius: var(--radius-full);
  }

  .prod-status {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-full);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .prod-status--active {
    background: #e6f4ea;
    color: var(--color-success);
  }

  .prod-status--inactive {
    background: #fce8e6;
    color: var(--color-error);
  }

  .prod-action-edit,
  .prod-action-delete {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: all 120ms var(--ease-out);
    border: none;
    font-family: var(--font-body);
  }

  .prod-action-edit {
    background: var(--color-emerald-glass);
    color: var(--color-emerald);
  }

  .prod-action-edit:hover {
    background: var(--color-emerald-glass2);
    color: var(--color-emerald-dark);
  }

  .prod-action-delete {
    background: transparent;
    color: var(--color-stone);
  }

  .prod-action-delete:hover {
    background: rgba(196, 69, 54, 0.08);
    color: var(--color-error);
  }

  .prod-delete-form {
    display: inline;
    margin: 0;
    margin-left: 0.25rem;
  }

  .prod-td--actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.25rem;
  }

  .prod-empty {
    text-align: center;
    padding: 3rem 1rem;
  }

  .prod-empty__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .prod-empty__inner p {
    color: var(--color-stone);
    font-size: 0.9rem;
    max-width: none;
    margin: 0;
  }

  .prod-empty__inner a {
    color: var(--color-emerald);
    text-decoration: underline;
    font-weight: 600;
  }
</style>
