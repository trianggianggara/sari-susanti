---
import AdminLayout from '../../../layouts/AdminLayout.astro';

export const prerender = false;

const { supabase } = Astro.locals;

// ── Known settings schema ──
const SETTINGS_SCHEMA = [
  {
    group: 'Banner Promo',
    fields: [
      { key: 'promo_banner_active', label: 'Tampilkan Banner', type: 'checkbox', placeholder: '' },
      { key: 'promo_banner_text_id', label: 'Teks Banner (Bahasa Indonesia)', type: 'text', placeholder: 'Contoh: Diskon 20% untuk pemesanan pertama!' },
      { key: 'promo_banner_text_en', label: 'Teks Banner (English)', type: 'text', placeholder: 'e.g. 20% off for your first order!' },
      { key: 'promo_banner_cta_id', label: 'Teks Tombol CTA (Bahasa Indonesia)', type: 'text', placeholder: 'Contoh: Klaim Promo' },
      { key: 'promo_banner_cta_en', label: 'Teks Tombol CTA (English)', type: 'text', placeholder: 'e.g. Claim Promo' },
      { key: 'promo_banner_link', label: 'Link Tujuan CTA', type: 'text', placeholder: '/order atau https://...' },
    ],
  },
] as const;

// Flatten keys for easy iteration
const ALL_KEYS = SETTINGS_SCHEMA.flatMap((g) => g.fields.map((f) => f.key));

let error = '';

// ── Handle POST ──
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();

  // Build updates
  const updates = ALL_KEYS.map((key) => {
    if (key === 'promo_banner_active') {
      return { key, value: formData.get(key) === 'on' ? 'true' : 'false' };
    }
    return { key, value: (formData.get(key) as string) ?? '' };
  });

  // Upsert each setting (update if exists)
  let hasError = false;
  for (const { key, value } of updates) {
    const { error: upsertError } = await supabase
      .from('site_settings')
      .update({ value, updated_at: new Date().toISOString() })
      .eq('key', key);

    if (upsertError) {
      console.error(`Failed to update setting ${key}:`, upsertError);
      hasError = true;
    }
  }

  if (hasError) {
    return Astro.redirect('/admin/settings?error=Pengaturan+berhasil+disimpan+sebagian.+Silakan+periksa+kembali.');
  }
  return Astro.redirect('/admin/settings?success=Pengaturan+berhasil+disimpan.');
}

// ── Fetch current values ──
const { data: settingsRows, error: fetchError } = await supabase
  .from('site_settings')
  .select('key, value, description')
  .in('key', ALL_KEYS);

if (fetchError) {
  console.error(fetchError);
}

const settingsMap = new Map<string, string>();
settingsRows?.forEach((row) => {
  settingsMap.set(row.key, String(row.value));
});

function getValue(key: string, type: 'text' | 'checkbox'): string | boolean {
  const raw = settingsMap.get(key) ?? '';
  if (type === 'checkbox') {
    return raw === 'true';
  }
  return raw;
}
---

<AdminLayout title="Pengaturan Situs">
  <div class="max-w-[720px]">
    <div class="flex justify-between items-center mb-6">
      <h2 class="m-0 font-display text-emerald-dark text-2xl">Pengaturan Situs</h2>
    </div>

    {error && (
      <div class="bg-red-600 text-white p-3 rounded-md mb-4 text-sm">
        {error}
      </div>
    )}

    <form method="POST" class="space-y-6">
      {SETTINGS_SCHEMA.map((group) => (
        <div class="bg-white rounded-lg border border-sand shadow-brand-sm overflow-hidden">
          <div class="px-6 py-4 border-b border-sand bg-ivory-warm">
            <h3 class="m-0 font-display text-emerald-dark text-lg">{group.group}</h3>
          </div>
          <div class="p-6 space-y-5">
            {group.fields.map((field) => {
              const value = getValue(field.key, field.type);
              const desc = settingsRows?.find(r => r.key === field.key)?.description;
              return (
                <div>
                  {field.type === 'checkbox' ? (
                    <label class="flex items-center gap-3 font-semibold text-sm text-charcoal cursor-pointer">
                      <input
                        type="checkbox"
                        name={field.key}
                        checked={value as boolean}
                        class="w-4 h-4 text-emerald-dark accent-emerald-dark"
                      />
                      <span>{field.label}</span>
                    </label>
                  ) : (
                    <>
                      <label class="block mb-2 font-semibold text-sm text-charcoal">
                        {field.label}
                      </label>
                      <input
                        type={field.type}
                        name={field.key}
                        value={value as string}
                        placeholder={field.placeholder}
                        class="w-full p-3 border border-sand rounded-sm box-border font-body text-base transition-all duration-150 focus:border-gold focus:ring-4 focus:ring-gold-glass focus:outline-none"
                      />
                    </>
                  )}
                  {desc && (
                    <p class="mt-1.5 text-xs text-stone">{desc}</p>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      ))}

      <div class="flex gap-4 pt-2">
        <button
          type="submit"
          class="bg-emerald-dark text-white border-none py-3 px-6 rounded-md font-bold cursor-pointer transition-colors hover:bg-emerald-light shadow-brand-sm"
        >
          Simpan Perubahan
        </button>
        <a
          href="/admin"
          class="inline-block py-3 px-6 text-charcoal no-underline border border-sand rounded-md font-bold transition-colors hover:bg-ivory-warm"
        >
          Batal
        </a>
      </div>
    </form>
  </div>
</AdminLayout>
