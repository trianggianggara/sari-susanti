---
import AdminLayout from '../../layouts/AdminLayout.astro';

export const prerender = false;

const { supabase } = Astro.locals;

// Fetch some basic stats
const { count: productsCount } = await supabase.from('products').select('*', { count: 'exact', head: true });
const { count: categoriesCount } = await supabase.from('categories').select('*', { count: 'exact', head: true });
const { count: testimonialsCount } = await supabase.from('testimonials').select('*', { count: 'exact', head: true });

const stats = [
  { label: 'Total Produk', value: productsCount || 0, color: 'var(--color-emerald)' },
  { label: 'Kategori Menu', value: categoriesCount || 0, color: 'var(--color-gold)' },
  { label: 'Ulasan Pelanggan', value: testimonialsCount || 0, color: 'var(--color-emerald-light)' },
];
---

<AdminLayout title="Dashboard">
  <div class="relative p-4 isolate">
    
    <header class="relative bg-emerald-dark text-white px-8 py-10 rounded-lg overflow-hidden mb-10 shadow-brand-xl animate-[slideUpFade_0.8s_ease-out_forwards] opacity-0">
      <div class="relative z-10 max-w-[600px]">
        <p class="text-gold font-body uppercase tracking-widest text-xs font-semibold mb-3">Sari Susanti Catering & Bakery</p>
        <h1 class="text-ivory font-display text-4xl leading-tight mb-4">Selamat Datang, Admin</h1>
        <p class="text-sand text-base leading-relaxed">Kelola sajian kuliner Nusantara dan pantau aktivitas website Anda melalui panel kontrol eksklusif ini.</p>
      </div>
      <div class="absolute -right-[5%] -bottom-[20%] w-[300px] h-[300px] bg-[radial-gradient(circle,var(--color-emerald-light)_0%,transparent_70%)] opacity-40 rounded-full z-0 blur-[40px]"></div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
      {stats.map((stat, index) => (
        <div class="relative bg-white p-8 rounded-lg shadow-brand-md border border-sand overflow-hidden flex items-center transition-transform transition-shadow duration-250 ease-out hover:-translate-y-1 hover:shadow-brand-xl animate-[slideUpFade_0.8s_ease-out_forwards] opacity-0" style={`animation-delay: ${index * 150}ms`}>
          <div class="absolute top-0 left-0 bottom-0 w-[6px]" style={`background-color: ${stat.color}`}></div>
          <div class="relative z-10">
            <h3 class="m-0 text-stone font-body text-sm uppercase tracking-wide font-semibold">{stat.label}</h3>
            <p class="mt-2 font-display text-5xl text-emerald-dark leading-none">{stat.value}</p>
          </div>
          <div class="absolute -right-2 -bottom-5 font-display text-[8rem] font-bold text-sand-light opacity-30 z-0 pointer-events-none leading-none">{stat.value}</div>
        </div>
      ))}
    </div>

    <section class="animate-[slideUpFade_0.8s_ease-out_forwards] opacity-0" style="animation-delay: 450ms">
      <h2 class="font-display text-emerald-dark text-2xl mb-6 relative inline-block after:content-[''] after:absolute after:-bottom-2 after:left-0 after:w-10 after:h-0.5 after:bg-gold">Aksi Cepat</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="/admin/products/new" class="flex items-start gap-4 bg-white p-6 rounded-md border border-sand no-underline transition-all duration-150 ease-out hover:bg-ivory-warm hover:border-gold hover:shadow-brand-md group">
          <div class="text-2xl bg-ivory-warm w-12 h-12 flex items-center justify-center rounded-full transition-colors duration-150 group-hover:bg-emerald-glass2">✨</div>
          <div>
            <h3 class="m-0 mb-1 text-emerald-dark text-lg font-display">Tambah Produk Baru</h3>
            <p class="m-0 text-stone text-sm">Perbarui etalase menu katering Anda.</p>
          </div>
        </a>
        <a href="/admin/testimonials/new" class="flex items-start gap-4 bg-white p-6 rounded-md border border-sand no-underline transition-all duration-150 ease-out hover:bg-ivory-warm hover:border-gold hover:shadow-brand-md group">
          <div class="text-2xl bg-ivory-warm w-12 h-12 flex items-center justify-center rounded-full transition-colors duration-150 group-hover:bg-emerald-glass2">🌟</div>
          <div>
            <h3 class="m-0 mb-1 text-emerald-dark text-lg font-display">Tambah Testimoni</h3>
            <p class="m-0 text-stone text-sm">Bagikan kepuasan pelanggan terbaru.</p>
          </div>
        </a>
      </div>
    </section>

  </div>
</AdminLayout>

<style>
  /* Animations can still use Tailwind's arbitrary values, but keeping the keyframes here is cleaner for complex ones if needed. 
     Tailwind v3 arbitrary variants take care of it nicely: animate-[slideUpFade_0.8s_ease-out_forwards] */
  @keyframes slideUpFade {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }
</style>
