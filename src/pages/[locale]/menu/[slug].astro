---
import { LOCALES } from '../../../i18n/utils';
import type { Locale } from '../../../i18n/utils';
import { useTranslations } from '../../../i18n/utils';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { formatPrice } from '../../../lib/format';
import { buildWhatsAppUrl } from '../../../lib/whatsapp';

export function getStaticPaths() {
  const mockProducts = [
    { slug: 'nasi-kotak-premium', category: 'sari-savory', name: 'Nasi Kotak Premium', short_description: 'Nasi putih, ayam bakar madu, sambal goreng kentang, telur balado, kerupuk, buah.', description: 'Nasi Kotak Premium dari Sari Susanti menyajikan hidangan lengkap yang cocok untuk berbagai acara. Dikemas secara higienis dan rapi, setiap kotaknya berisi lauk pauk berkualitas yang dimasak dengan rempah pilihan.', price: 35000 },
    { slug: 'tumpeng-mini', category: 'sari-tumpeng', name: 'Tumpeng Mini', short_description: 'Nasi kuning, ayam goreng, perkedel, kering tempe, telur iris, sambal.', description: 'Tumpeng Mini sangat pas untuk syukuran kecil, ulang tahun, atau sekadar dinikmati bersama keluarga. Dibuat dengan resep asli nasi kuning Nusantara yang gurih dan wangi.', price: 40000 },
    { slug: 'snack-box-manis', category: 'sari-sweet', name: 'Snack Box Manis', short_description: 'Pie buah, risoles mayo, bolu kukus, air mineral.', description: 'Pilihan tepat untuk coffee break atau camilan acara Anda. Terdiri dari perpaduan kue manis dan gurih yang dibuat fresh setiap harinya.', price: 15000 },
    { slug: 'nasi-besek', category: 'sari-savory', name: 'Nasi Besek Tradisional', short_description: 'Nasi liwet, ayam goreng kampung, tahu tempe bacem, ikan asin, lalapan, sambal terasi.', description: 'Membawa nostalgia rasa pedesaan, Nasi Besek disajikan dalam kemasan anyaman bambu tradisional yang ramah lingkungan. Dilengkapi dengan lauk pauk klasik yang membangkitkan selera makan.', price: 45000 },
  ];

  return LOCALES.flatMap((locale) => 
    mockProducts.map(product => ({
      params: { locale, slug: product.slug },
      props: { product }
    }))
  );
}

const { locale } = Astro.params as { locale: Locale };
const { product } = Astro.props;
const t = useTranslations(locale);
---

<BaseLayout 
  locale={locale}
  title={`${product.name} | ${t('meta.menu.title')}`}
  description={product.short_description}
>
  <div class="product-detail-page">
    <div class="container">
      <a href={`/${locale}/menu`} class="back-link reveal">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        {t('menu.back')}
      </a>

      <div class="detail-grid">
        <div class="detail-image reveal-scale">
          <img src="/placeholder.jpg" alt={product.name} />
        </div>
        
        <div class="detail-content reveal-right">
          <div class="detail-header">
            <span class="detail-category">Sari Savory</span>
            <h1 class="detail-title">{product.name}</h1>
          </div>

          <div class="detail-price-box">
            <span class="price-label">{t('menu.price_from')}</span>
            <div class="price-amount">{formatPrice(product.price, locale)}</div>
          </div>

          <div class="detail-desc">
            <p>{product.description}</p>
          </div>

          <div class="detail-actions">
            <a 
              href={buildWhatsAppUrl(locale, product.name)} 
              class="btn btn-whatsapp btn-lg w-full"
              target="_blank" rel="noopener noreferrer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
              </svg>
              {t('menu.order_now')}
            </a>
          </div>

          <div class="detail-info">
            <div class="info-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              <span>Pemesanan H-3</span>
            </div>
            <div class="info-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10.08 10.08 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <span>Halal & Higienis</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .product-detail-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-section);
    background: var(--color-ivory);
    min-height: 80vh;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-stone);
    margin-bottom: var(--space-8);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .back-link:hover {
    color: var(--color-emerald);
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: flex-start;
  }

  .detail-image {
    background: var(--color-white);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-sand);
    aspect-ratio: 4/4;
    position: sticky;
    top: calc(var(--nav-height) + var(--space-8));
  }

  .detail-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .detail-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .detail-category {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-emerald);
    margin-bottom: var(--space-2);
  }

  .detail-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    color: var(--color-charcoal);
    line-height: var(--leading-tight);
  }

  .detail-price-box {
    padding: var(--space-6);
    background: var(--color-white);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-sand);
    box-shadow: var(--shadow-sm);
  }

  .price-label {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-stone);
    margin-bottom: var(--space-1);
  }

  .price-amount {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-gold-dark);
  }

  .detail-desc {
    font-size: var(--text-lg);
    color: var(--color-charcoal-light);
    line-height: var(--leading-relaxed);
  }

  .w-full {
    width: 100%;
  }

  .detail-info {
    display: flex;
    gap: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-sand);
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-stone);
  }

  @media (max-width: 900px) {
    .detail-grid {
      grid-template-columns: 1fr;
    }
    .detail-image {
      position: static;
      aspect-ratio: 4/3;
    }
  }
</style>
