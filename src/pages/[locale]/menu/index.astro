---
import { LOCALES } from "../../../i18n/utils";
import type { Locale } from "../../../i18n/utils";
import { useTranslations } from "../../../i18n/utils";
import type { LocalizedProduct, LocalizedCategory } from "../../../types/app";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SectionHeading from "../../../components/common/SectionHeading.astro";
import { formatPrice } from "../../../lib/format";
import { buildWhatsAppUrl } from "../../../lib/whatsapp";

import { supabasePublic } from "../../../lib/supabase";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);
const isEn = locale === 'en';

const [{ data: categories }, { data: products }] = await Promise.all([
  supabasePublic
    .from("categories")
    .select("id, slug, name, name_en")
    .eq("is_active", true)
    .order("sort_order", { ascending: true }),
  supabasePublic
    .from("products")
    .select(
      `
      slug, name, name_en, short_description, short_description_en, price, image_url,
      categories (
        slug, name, name_en
      )
    `,
    )
    .eq("is_active", true)
    .order("sort_order", { ascending: true }),
]) as any;

const activeCategories = (categories as any as LocalizedCategory[]) || [];
const activeProducts = (products as any as LocalizedProduct[]) || [];
---

<BaseLayout
  locale={locale}
  title={t("meta.menu.title")}
  description={t("meta.menu.desc")}
>
  <div class="menu-page">
    <div class="container">
      <SectionHeading
        eyebrow={t("menu.eyebrow")}
        title={t("menu.title")}
        subtitle={t("menu.subtitle")}
      />

      <div class="category-tabs reveal">
        <button class="category-tab is-active" data-category="all"
          >{t("categories.all")}</button
        >
        {
          activeCategories.map((cat) => (
            <button class="category-tab" data-category={cat.slug}>
              {locale === "en" ? cat.name_en || cat.name : cat.name}
            </button>
          ))
        }
      </div>

      <div class="grid-3 product-grid">
        {
          activeProducts.map((product) => (
            <div
              class="product-card reveal"
              data-category={product.categories?.slug}
            >
              <a
                href={`/${locale}/menu/${product.slug}`}
                class="product-card__image"
              >
                <img
                  src={product.image_url || "/placeholder.jpg"}
                  alt={
                    locale === "en"
                      ? product.name_en || product.name
                      : product.name
                  }
                  loading="lazy"
                />
              </a>
              <div class="product-card__body">
                <span class="product-card__category">
                  {locale === "en"
                    ? product.categories?.name_en || product.categories?.name
                    : product.categories?.name}
                </span>
                <h3 class="product-card__name">
                  <a href={`/${locale}/menu/${product.slug}`}>
                    {locale === "en"
                      ? product.name_en || product.name
                      : product.name}
                  </a>
                </h3>
                <p class="product-card__desc">
                  {locale === "en"
                    ? product.short_description_en || product.short_description
                    : product.short_description}
                </p>
                <div class="product-card__footer">
                  <div class="product-card__price">
                    <span class="product-card__price-label">
                      {t("menu.price_from")}
                    </span>
                    <span class="product-card__price-value">
                      {formatPrice(product.price, locale)}
                    </span>
                  </div>
                  <button
                    class="btn btn--primary btn--sm btn-add-cart"
                    data-slug={product.slug}
                    data-name={locale === "en" ? product.name_en || product.name : product.name}
                    data-price={product.price ?? ''}
                    data-image={product.image_url || ''}
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-right:5px">
                      <line x1="12" y1="5" x2="12" y2="19"></line>
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    {isEn ? 'Add to Order' : 'Tambah Pesanan'}
                  </button>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .menu-page {
    padding-top: var(--space-section);
    padding-bottom: var(--space-section);
    background: var(--color-ivory);
    min-height: 80vh;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll(".category-tab");
    const products = document.querySelectorAll(".product-card");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        // Update active tab
        tabs.forEach((t) => t.classList.remove("is-active"));
        tab.classList.add("is-active");

        // Filter products
        const category = tab.getAttribute("data-category");
        products.forEach((product) => {
          const productCategory = product.getAttribute("data-category");
          if (category === "all" || category === productCategory) {
            (product as HTMLElement).style.display = "flex";
            // Slight animation re-trigger
            (product as HTMLElement).style.animation = "none";
            (product as HTMLElement).offsetHeight; /* trigger reflow */
            (product as HTMLElement).style.animation =
              "fadeUp 0.5s var(--ease-out) forwards";
          } else {
            (product as HTMLElement).style.display = "none";
          }
        });
      });
    });
  });
</script>

<script>
  // Add to Cart handler
  const CART_KEY = 'ss_cart';
  const CART_EVENT = 'ss:cart-updated';
  function getItems() { try { return JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch { return []; } }
  function saveItems(items) {
    localStorage.setItem(CART_KEY, JSON.stringify(items));
    window.dispatchEvent(new CustomEvent(CART_EVENT, { detail: items }));
  }

  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.btn-add-cart');
    if (!btn) return;

    const { slug, name, price, image } = btn.dataset;
    const items = getItems();
    const existing = items.find(i => i.slug === slug);
    if (existing) {
      existing.qty += 1;
    } else {
      items.push({ slug, name, price: price ? Number(price) : null, image, qty: 1 });
    }
    saveItems(items);

    // Visual feedback
    const original = btn.innerHTML;
    btn.innerHTML = '✓ ' + (btn.textContent.trim().startsWith('Add') ? 'Added!' : 'Ditambahkan!');
    btn.disabled = true;
    setTimeout(() => { btn.innerHTML = original; btn.disabled = false; }, 1200);

    // Open cart drawer
    window.dispatchEvent(new CustomEvent('ss:open-cart'));
  });
</script>
