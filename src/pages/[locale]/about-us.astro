---
import { LOCALES } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/common/SectionHeading.astro';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);
---

<BaseLayout 
  locale={locale}
  title={t('meta.about.title')}
  description={t('meta.about.desc')}
>
  <div class="about-page">
    <div class="container container--narrow">
      <SectionHeading 
        eyebrow={t('about.eyebrow')}
        title={t('about_story.title')}
        subtitle={t('about_story.subtitle')}
      />

      <div class="story-content reveal">
        <img src="/sari-family.png" alt="Sari Susanti Family" class="story-hero-img" />
        
        <div class="story-text">
          <p class="dropcap">{t('about_story.dropcap')}</p>
          <p>{t('about_story.p1')}</p>
          
          <p set:html={t('about_story.p2')} />

          <blockquote class="story-quote">
            {t('about_story.quote')}
          </blockquote>

          <p>{t('about_story.p3')}</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    padding-top: var(--space-section);
    padding-bottom: var(--space-section);
    background: var(--color-ivory);
    min-height: 80vh;
  }

  .story-hero-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-2xl);
    margin-bottom: var(--space-12);
    box-shadow: var(--shadow-lg);
  }

  .story-text {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-charcoal-light);
    max-width: 75ch;
    margin-inline: auto;
  }

  .story-text p {
    margin-bottom: var(--space-6);
  }

  .dropcap {
    float: left;
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 0.8;
    padding-top: 4px;
    padding-right: 8px;
    padding-left: 3px;
    color: var(--color-gold-dark);
  }

  .story-quote {
    font-family: var(--font-accent);
    font-size: var(--text-2xl);
    font-style: italic;
    color: var(--color-emerald);
    text-align: center;
    margin-block: var(--space-10);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-sand);
    border-bottom: 1px solid var(--color-sand);
  }
</style>
