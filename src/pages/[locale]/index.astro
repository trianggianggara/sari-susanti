---
import { LOCALES } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroBanner from '../../components/home/HeroBanner.astro';
import FeaturedMenu from '../../components/home/FeaturedMenu.astro';
import AboutPreview from '../../components/home/AboutPreview.astro';
import TestimonialSection from '../../components/home/TestimonialSection.astro';
import FaqSection from '../../components/home/FaqSection.astro';
import CtaSection from '../../components/home/CtaSection.astro';
import { supabasePublic } from '../../lib/supabase';

// We need to define getStaticPaths for dynamic routing
export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

// Fetch data from Supabase for SSG build
const [
  { data: products },
  { data: testimonials },
  { data: faqs }
] = await Promise.all([
  supabasePublic.from('products')
    .select('slug, name, name_en, short_description, short_description_en, price, image_url, is_featured')
    .eq('is_active', true)
    .eq('is_featured', true),
  supabasePublic.from('testimonials')
    .select('customer_name, customer_role, customer_avatar_url, content, content_en, rating')
    .eq('is_active', true)
    .order('sort_order', { ascending: true }),
  supabasePublic.from('faqs')
    .select('question, question_en, answer, answer_en')
    .eq('is_active', true)
    .order('sort_order', { ascending: true })
]);

---

<BaseLayout locale={locale}>
  <HeroBanner locale={locale} />
  <FeaturedMenu locale={locale} products={products || []} />
  <AboutPreview locale={locale} />
  <TestimonialSection locale={locale} testimonials={testimonials || []} />
  <FaqSection locale={locale} faqs={faqs || []} />
  <CtaSection locale={locale} />
</BaseLayout>
