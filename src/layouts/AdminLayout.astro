---
import BaseHead from '../components/common/BaseHead.astro';
import AdminSidebar from '../components/admin/AdminSidebar';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <BaseHead locale="id" title={`${title} - Admin CMS Sari Susanti`} description="Admin CMS" />
  <body class="bg-ivory-warm m-0 font-body text-charcoal">
    <div class="flex min-h-screen">
      <AdminSidebar client:load currentPath={Astro.url.pathname} />
      <div class="flex-1 flex flex-col bg-ivory-warm">
        <header class="bg-white px-8 py-4 border-b border-sand flex justify-between items-center shadow-brand-sm z-50">
          <h2 class="m-0 font-display text-emerald-dark text-2xl">{title}</h2>
          <div>
            <form action="/api/auth/logout" method="POST">
              <button type="submit" class="bg-transparent border-none text-red-600 cursor-pointer font-body font-semibold text-sm transition-opacity duration-150 ease-out hover:opacity-70">Logout</button>
            </form>
          </div>
        </header>
        <main class="p-8 flex-1 overflow-y-auto">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
